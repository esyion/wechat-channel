{
  "name": "@esyion/wechat-channel",
  "version": "0.2.1",
  "description": "Agent-agnostic WeChat ilink channel library. Bridges long-poll protocol to user-defined handlers.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/esyion/wechat-channel"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "wechat-channel": "./dist/bin/migrate-credentials.js"
  },
  "files": [
    "dist",
    "dist-cjs",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist-cjs/package.json', JSON.stringify({type:'commonjs'}))\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --pool=forks --passWithNoTests",
    "test:watch": "vitest --pool=forks"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qr": "^0.6.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
