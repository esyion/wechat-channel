{
  "name": "wechat-agent-channel",
  "version": "0.1.0",
  "description": "Bridge between WeChat (ilink protocol) and Claude Agent SDK",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "wechat-agent-channel": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsx src/index.ts",
    "login": "node --enable-source-maps dist/login.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "dotenv": "^16.4.5",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
