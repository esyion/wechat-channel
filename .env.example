# ====== WeChat (ilink) ======
# Default base URL for ilink gateway
WECHAT_BASE_URL=https://ilinkai.weixin.qq.com

# CDN base URL for media upload/download
WECHAT_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c

# Bot token from QR login. Run `npm run login` to obtain.
# After login, the token is persisted to ~/.wechat-agent-channel/accounts/<accountId>.json (chmod 600)
WECHAT_BOT_TOKEN=

# Bot account ID (ilink_bot_id, e.g. "x9f8e7d6c5b4a-im-bot")
# Optional — auto-discovered from login state if blank
WECHAT_ACCOUNT_ID=

# Bot agent string (sent in base_info; defaults to "wechat-agent-channel/0.1.0")
WECHAT_BOT_AGENT=

# ====== Claude Agent SDK ======
# Anthropic API key (required). The SDK also supports OAuth via Claude Code login.
ANTHROPIC_API_KEY=sk-ant-...

# Custom Anthropic-compatible endpoint (e.g. proxy, LiteLLM, vLLM, AWS Bedrock adapter).
# When set, all sampling requests go through this URL instead of api.anthropic.com.
# Aliases: ANTHROPIC_BASE_URL (read by `claude` CLI natively).
# Example: CLAUDE_BASE_URL=https://your-proxy.example.com
# CLAUDE_BASE_URL=

# Custom auth token. Overrides ANTHROPIC_API_KEY when set.
# Useful when routing through a proxy that issues its own tokens.
# Aliases: ANTHROPIC_AUTH_TOKEN.
# CLAUDE_AUTH_TOKEN=

# Claude model (default: claude-sonnet-4-6).
# Override this if your proxy maps to a different name (e.g. claude-sonnet-proxy-v1).
CLAUDE_MODEL=claude-sonnet-4-6

# Working directory that Claude operates on (passed as cwd to the agent)
CLAUDE_WORK_DIR=./workspace

# Allowed tools for Claude (comma-separated). Empty = all tools.
# Examples: "Read,Bash,Edit,Write,Glob,Grep"
CLAUDE_ALLOWED_TOOLS=

# Max conversation turns per user session (0 = unlimited)
CLAUDE_MAX_TURNS=0

# Logger "trace" | "debug" | "info" | "warn" | "error" | "fatal" (default: "info")
LOG_LEVEL=debug


# ====== Bot behavior ======
# Max outbound text per message (WeChat recommended: 4000)
MAX_TEXT_CHARS=4000

# Long-poll timeout in ms (server may hold up to ~60s)
LONG_POLL_TIMEOUT_MS=35000

# Skip messages from these user IDs (comma-separated, optional)
# BLOCKED_USERS=

# Working directory for inbound media (downloaded from CDN)
MEDIA_TMP_DIR=./tmp/media
